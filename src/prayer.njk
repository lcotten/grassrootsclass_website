---
layout: layouts/base.njk
title: Prayer
heroTitle: Prayer Requests
heroText: Share requests so the class can pray with care and consistency.
description: Prayer request page for the class.
permalink: /prayer/index.html
---
<section class="card-stack">
  <article class="card">
    <h2>Submit a Prayer Request</h2>
    <form class="stacked-form" action="/api/prayer" method="post" data-async-form>
      <input class="visually-hidden" name="website" type="text" tabindex="-1" autocomplete="off">

      <label for="prayer-name">Name</label>
      <input id="prayer-name" name="name" type="text" placeholder="Your name">

      <label for="prayer-email">Email Address (optional)</label>
      <input id="prayer-email" name="email" type="email" placeholder="you@example.com">

      <label for="prayer-phone">Phone Number (optional)</label>
      <input
        id="prayer-phone"
        name="phone"
        type="tel"
        placeholder="(555) 555-5555"
        pattern="^(?:\\(\\d{3}\\)|\\d{3})[\\s.-]?\\d{3}[\\s.-]?\\d{4}$"
        title="Enter a valid 10-digit US phone number (example: 5555555555 or (555) 555-5555)."
      >

      <label for="prayer-request">Prayer Request</label>
      <textarea id="prayer-request" name="request" rows="6" placeholder="How can we pray for you?" required></textarea>

      <button type="submit">Submit</button>
      <p class="form-status" data-form-status aria-live="polite"></p>
    </form>
  </article>
</section>
