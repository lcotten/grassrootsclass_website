<nav class="site-nav" aria-label="Main navigation">
  <div class="site-nav__bar">
    <button class="site-nav__toggle" type="button" aria-expanded="false" aria-controls="site-nav-links">
      <span class="site-nav__toggle-text">Menu</span>
      <span class="site-nav__toggle-icon" aria-hidden="true"></span>
    </button>
  </div>
  <div class="site-nav__links" id="site-nav-links">
    {% for item in site.nav %}
      <a href="{{ item.url }}" {% if page.url == item.url %}aria-current="page"{% endif %}>{{ item.label }}</a>
    {% endfor %}
  </div>
</nav>
